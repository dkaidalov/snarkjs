  let beta = builtin.bls12_381_g2_uncompress(vk_beta_2)
  let gamma = builtin.bls12_381_g2_uncompress(vk_gamma_2)
  let delta = builtin.bls12_381_g2_uncompress(vk_delta_2)

  // Compute vk_x = IC[0] + sum(public_signals[i] * IC[i+1])
